{
  "name": "integradora",
  "version": "1.0.0",
  "description": "Este es un repositorio para el proyecto Lost & Found",
  "scripts": {
    "dev:back": "npm --prefix LF_BACK run dev",
    "dev:front": "npm --prefix LF run start -- --proxy-config proxy.conf.json",
    "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
